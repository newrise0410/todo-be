# 서버 포트
PORT=4000

# MongoDB 연결 문자열
# 로컬:  mongodb://127.0.0.1:27017/todo
# Atlas: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/todo
MONGODB_URI=mongodb://127.0.0.1:27017/todo

# MiniMax LLM (자연어 스마트 추가). 키는 서버에만 보관.
MINIMAX_API_KEY=
# 선택: 기본값 사용 시 생략 가능
# MINIMAX_MODEL=MiniMax-M3
# MINIMAX_BASE_URL=https://api.minimax.io/v1
